\contentsline {figure}{\numberline {4.2}{\ignorespaces IAR EWARM project structure for the USB HID benchmark: STM32 reference (left) and GD32 target (right).}}{48}{figure.caption.41}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces UART terminal output of the FreeRTOS cooperative benchmark: thread iteration counters reported every 30 seconds on STM32 (left) and GD32 (right).}}{54}{figure.caption.50}%
