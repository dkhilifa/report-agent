<mxfile host="app.diagrams.net">
  <diagram id="routing" name="Routing Workflow">
    <mxGraphModel dx="1100" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="title" value="Benchmark Lifecycle — Agent Creates, Studio Analyses" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="280" y="20" width="480" height="30" as="geometry" /></mxCell>
        <!-- Step 1: Understand -->
        <mxCell id="s1" value="1. Understand&#10;reference project&#10;(benchmark-analysis)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="160" height="70" as="geometry" /></mxCell>
        <!-- Step 2: Create/Port -->
        <mxCell id="s2" value="2. Create / port&#10;target project&#10;(Creation-Porting)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="80" width="160" height="70" as="geometry" /></mxCell>
        <!-- Step 3: Build -->
        <mxCell id="s3" value="3. Configure build&#10;(Build-Project)&#10;IAR EWARM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="440" y="80" width="160" height="70" as="geometry" /></mxCell>
        <!-- Step 4: Debug -->
        <mxCell id="s4" value="4. Debug from&#10;real evidence&#10;(Debugger)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="640" y="80" width="160" height="70" as="geometry" /></mxCell>
        <!-- Step 5: Validate semantics -->
        <mxCell id="s5" value="5. Validate&#10;semantic equivalence&#10;(17-point checklist)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="840" y="80" width="160" height="70" as="geometry" /></mxCell>
        <!-- Decision diamond -->
        <mxCell id="dec" value="Semantically&#10;equivalent?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="860" y="200" width="120" height="90" as="geometry" /></mxCell>
        <!-- Loop back -->
        <mxCell id="loop_label" value="Fix drift" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#b85450;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="480" y="210" width="60" height="25" as="geometry" /></mxCell>
        <!-- Step 6: Linker map output -->
        <mxCell id="s6" value="6. Produce&#10;linker map (.map)&#10;(validated build)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="840" y="340" width="160" height="70" as="geometry" /></mxCell>
        <!-- Handoff arrow -->
        <mxCell id="handoff" value="" style="shape=mxgraph.arrows2.arrow;dy=0.6;dx=30;notch=0;fillColor=#6c8ebf;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="870" y="440" width="100" height="30" as="geometry" /></mxCell>
        <!-- MCU Workflow Studio -->
        <mxCell id="studio" value="MCU Workflow Studio&#10;(Footprint Analysis)&#10;&#10;Deterministic comparison,&#10;per-layer breakdown,&#10;exportable results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="790" y="500" width="220" height="110" as="geometry" /></mxCell>
        <!-- Edges -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e45" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5dec" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="s5" target="dec"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_yes" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1" source="dec" target="s6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_no" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;fontSize=11;strokeColor=#b85450;fontColor=#b85450;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="dec" target="s2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="500" y="245" /><mxPoint x="500" y="180" /><mxPoint x="320" y="180" /></Array></mxGeometry></mxCell>
        <mxCell id="e6studio" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="s6" target="studio"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Boundary labels -->
        <mxCell id="lbl_agent" value="MCU Benchmark Copilot Agent" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontStyle=3;fontColor=#82b366;" vertex="1" parent="1"><mxGeometry x="40" y="410" width="240" height="30" as="geometry" /></mxCell>
        <mxCell id="lbl_studio" value="MCU Workflow Studio" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontStyle=3;fontColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="40" y="440" width="170" height="30" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
