<mxfile host="app.diagrams.net" type="device">
  <diagram id="tool-sequence" name="Sequence">
    <mxGraphModel dx="1500" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="title" value="Footprint Benchmark Run — Sequence Diagram" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="500" y="10" width="500" height="30" as="geometry" /></mxCell>
        <!-- Participants (lifelines) -->
        <mxCell id="p1" value="&lt;b&gt;User&lt;/b&gt;&lt;br&gt;(CLI / GUI)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="50" width="100" height="930" as="geometry" /></mxCell>
        <mxCell id="p2" value="&lt;b&gt;Workflow&lt;br&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="230" y="50" width="100" height="930" as="geometry" /></mxCell>
        <mxCell id="p3" value="&lt;b&gt;Map&lt;br&gt;Parser&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="400" y="50" width="100" height="930" as="geometry" /></mxCell>
        <mxCell id="p4" value="&lt;b&gt;Layer&lt;br&gt;Classifier&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="50" width="100" height="930" as="geometry" /></mxCell>
        <mxCell id="p5" value="&lt;b&gt;Mapping&lt;br&gt;Engine&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="50" width="100" height="930" as="geometry" /></mxCell>
        <mxCell id="p6" value="&lt;b&gt;Equivalence&lt;br&gt;DB&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="50" width="100" height="930" as="geometry" /></mxCell>
        <mxCell id="p7" value="&lt;b&gt;Compare&lt;br&gt;Engine&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1040" y="50" width="100" height="930" as="geometry" /></mxCell>
        <mxCell id="p8" value="&lt;b&gt;Quality&lt;br&gt;Metrics&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1200" y="50" width="100" height="930" as="geometry" /></mxCell>
        <mxCell id="p9" value="&lt;b&gt;Export&lt;br&gt;Layer&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;participant=umlEntity;size=20;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1380" y="50" width="100" height="930" as="geometry" /></mxCell>
        <!-- Messages -->
        <!-- 1. User → Workflow: start benchmark -->
        <mxCell id="m1" value="1: benchmark(source.map, target.map, vendors)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="110" y="120" as="sourcePoint" /><mxPoint x="270" y="120" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 2. Workflow → Parser: parse source -->
        <mxCell id="m2" value="2: parse(source.map)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="160" as="sourcePoint" /><mxPoint x="440" y="160" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 2r. Parser → Workflow: source symbols -->
        <mxCell id="m2r" value="source_symbols[]" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="440" y="190" as="sourcePoint" /><mxPoint x="280" y="190" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 3. Workflow → Parser: parse target -->
        <mxCell id="m3" value="3: parse(target.map)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="220" as="sourcePoint" /><mxPoint x="440" y="220" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 3r. Parser → Workflow: target symbols -->
        <mxCell id="m3r" value="target_symbols[]" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="440" y="250" as="sourcePoint" /><mxPoint x="280" y="250" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 4. Workflow → Classifier: classify source -->
        <mxCell id="m4" value="4: classify(source_symbols)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="290" as="sourcePoint" /><mxPoint x="600" y="290" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 4r -->
        <mxCell id="m4r" value="layered_source[]" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="600" y="320" as="sourcePoint" /><mxPoint x="280" y="320" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 5. Workflow → Classifier: classify target -->
        <mxCell id="m5" value="5: classify(target_symbols)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="350" as="sourcePoint" /><mxPoint x="600" y="350" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 5r -->
        <mxCell id="m5r" value="layered_target[]" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="600" y="380" as="sourcePoint" /><mxPoint x="280" y="380" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 6. Workflow → Mapping Engine: map symbols -->
        <mxCell id="m6" value="6: map_symbols(layered_source, layered_target)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="420" as="sourcePoint" /><mxPoint x="760" y="420" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 7. Mapping → EquivDB: lookup equivalences -->
        <mxCell id="m7" value="7: lookup(peripheral_group, vendor_pair)" style="html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="770" y="460" as="sourcePoint" /><mxPoint x="920" y="460" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 7r -->
        <mxCell id="m7r" value="known_equivalences[]" style="html=1;endArrow=open;dashed=1;strokeColor=#9673a6;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="920" y="490" as="sourcePoint" /><mxPoint x="770" y="490" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 8. Mapping → Mapping: score 12 signals per pair -->
        <mxCell id="m8" value="8: score_candidates(12 signals, equivalences)" style="html=1;endArrow=block;endFill=1;strokeColor=#d6b656;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="770" y="530" as="sourcePoint" /><mxPoint x="810" y="530" as="targetPoint" /><Array as="points"><mxPoint x="830" y="530" /><mxPoint x="830" y="550" /><mxPoint x="770" y="550" /></Array></mxGeometry></mxCell>
        <!-- 8r. Mapping → Workflow: mapping_result -->
        <mxCell id="m8r" value="mapping_result (accepted / low-confidence / unmapped)" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="760" y="580" as="sourcePoint" /><mxPoint x="280" y="580" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 9. Workflow → Compare Engine: compute deltas -->
        <mxCell id="m9" value="9: compare(mapping_result, layers)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="620" as="sourcePoint" /><mxPoint x="1080" y="620" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 9r -->
        <mxCell id="m9r" value="per_layer_delta, global_delta, root_cause" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1080" y="660" as="sourcePoint" /><mxPoint x="280" y="660" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 10. Workflow → Quality Metrics -->
        <mxCell id="m10" value="10: compute_quality(source_firmware)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="700" as="sourcePoint" /><mxPoint x="1240" y="700" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 10r -->
        <mxCell id="m10r" value="grade, modularity, density, hotspots" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1240" y="730" as="sourcePoint" /><mxPoint x="280" y="730" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 11. Workflow → Export: generate outputs -->
        <mxCell id="m11" value="11: export(deltas, quality, manifest)" style="html=1;endArrow=block;endFill=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="780" as="sourcePoint" /><mxPoint x="1420" y="780" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 11r -->
        <mxCell id="m11r" value="Excel + CSV + JSON + PDF + manifest.json" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1420" y="820" as="sourcePoint" /><mxPoint x="280" y="820" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 12. Workflow → User: done -->
        <mxCell id="m12" value="12: results + run manifest" style="html=1;endArrow=open;dashed=1;strokeColor=#333333;fontSize=10;align=center;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="270" y="870" as="sourcePoint" /><mxPoint x="110" y="870" as="targetPoint" /></mxGeometry></mxCell>
        <!-- Interaction fragments / notes -->
        <mxCell id="note1" value="Deterministic: same inputs → same outputs&lt;br&gt;(stable sort, rounded scores, canonical ordering)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="1060" y="100" width="260" height="50" as="geometry" /></mxCell>
        <mxCell id="note2" value="Equivalence DB lookup boosts&lt;br&gt;confidence to ≥ 0.80 for known pairs" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="960" y="500" width="230" height="40" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
