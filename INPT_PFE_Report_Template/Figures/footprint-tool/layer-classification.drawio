<mxfile host="app.diagrams.net" modified="2026-06-04" agent="MCU Workflow Studio" type="device">
  <diagram name="Layer Classification" id="layer-07">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Layer Classification — Token Lexicons, Confidence &amp; LLM Override" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- INPUT -->
        <mxCell id="input" value="Input: ModuleRecord or FunctionRecord&#xa;(name + source_object)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;strokeWidth=2;fontSize=12;fontColor=#004D40;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="350" height="50" as="geometry"/>
        </mxCell>

        <!-- ═══ STEP 1: TOKENIZE ═══ -->
        <mxCell id="tok" value="STEP 1: Tokenize&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• Split name on _ and camelCase boundaries&#xa;• Split source_object on / and \\&#xa;• Lowercase all tokens&#xa;• Remove numeric suffixes and single chars" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#546E7A;strokeWidth=1;fontSize=11;fontColor=#37474F;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="440" y="170" width="600" height="100" as="geometry"/>
        </mxCell>

        <!-- ═══ STEP 2: LEXICON MATCH ═══ -->
        <mxCell id="lex_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="1520" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="lex_label" value="STEP 2: Match tokens against Layer Lexicons (9 built-in layers)" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontStyle=1;fontSize=13;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="60" y="315" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- Layer lexicons -->
        <mxCell id="lex1" value="🔧 Application&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;app, main, task, user,&#xa;cli, logic, business,&#xa;service, workflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;spacingLeft=6;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="60" y="355" width="170" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lex2" value="🖥️ GUI&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;gui, widget, screen,&#xa;display, ui, view,&#xa;button, dialog, panel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;spacingLeft=6;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="240" y="355" width="170" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lex3" value="📡 Communication&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;comm, can, spi, uart,&#xa;i2c, eth, tcp, udp,&#xa;modbus, lin, protocol" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;spacingLeft=6;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="420" y="355" width="170" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lex4" value="⚙️ Driver&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;drv, driver, hal, gpio,&#xa;adc, dac, pwm, timer,&#xa;flash, wdg, rtc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;spacingLeft=6;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="600" y="355" width="170" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lex5" value="🏗️ System&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;sys, system, init, startup,&#xa;config, clock, reset,&#xa;power, pwr, sleep" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;spacingLeft=6;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="780" y="355" width="170" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lex6" value="🔐 Security&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;crypto, aes, sha, rsa,&#xa;ssl, tls, auth, key,&#xa;cert, secure, hash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;spacingLeft=6;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="960" y="355" width="170" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lex7" value="📦 Middleware&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;rtos, os, freertos, cmsis,&#xa;thread, queue, mutex,&#xa;semaphore, event, heap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;spacingLeft=6;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="1140" y="355" width="170" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lex8" value="🔌 Runtime&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;crt, libc, runtime, math,&#xa;stdlib, newlib, startup,&#xa;vectors, exception" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;spacingLeft=6;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="1320" y="355" width="170" height="100" as="geometry"/>
        </mxCell>

        <!-- Scoring formula -->
        <mxCell id="lex_formula" value="Lexicon Score per layer: score_L = matching_tokens / total_tokens × boost_factor&#xa;boost_factor: 1.5 if source_object path matches layer pattern, else 1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;fontSize=10;fontColor=#1A237E;fontStyle=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="475" width="700" height="45" as="geometry"/>
        </mxCell>

        <!-- ═══ STEP 3: CONFIDENCE COMPUTE ═══ -->
        <mxCell id="conf_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="730" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="conf_label" value="STEP 3: Compute Classification Confidence" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontStyle=1;fontSize=13;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="60" y="625" width="450" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="conf_logic" value="best_layer = argmax(score_L for all L)&#xa;second_best = second highest score&#xa;&#xa;confidence = best_score - second_best_score&#xa;&#xa;Thresholds:&#xa;  confidence ≥ 0.6  → classification = best_layer&#xa;  confidence 0.3–0.59 → classification = best_layer (low_confidence flag)&#xa;  confidence &lt; 0.3  → classification = None (ambiguous)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;fontColor=#1B5E20;align=left;spacingLeft=15;verticalAlign=top;spacingTop=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="665" width="690" height="140" as="geometry"/>
        </mxCell>

        <!-- ═══ STEP 4: LLM OVERRIDE ═══ -->
        <mxCell id="llm_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="810" y="620" width="750" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="llm_label" value="STEP 4: LLM Override (optional, AI-assisted)" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontStyle=1;fontSize=13;fontColor=#F57F17;" vertex="1" parent="1">
          <mxGeometry x="830" y="625" width="450" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="llm_logic" value="Triggered when:&#xa;  • confidence &lt; 0.3 (ambiguous), OR&#xa;  • multiple layers within 0.1 of each other&#xa;&#xa;LLM prompt: &quot;Classify {name} from {path} into one of: [layers]&quot;&#xa;&#xa;Acceptance:&#xa;  • LLM response must match a valid layer name&#xa;  • Sets confidence = 0.5 + 0.1 (fixed bump)&#xa;  • Marks ai_override = 'llm_classification'&#xa;  • If LLM unavailable → remains None" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F57F17;fontSize=11;fontColor=#E65100;align=left;spacingLeft=15;verticalAlign=top;spacingTop=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="830" y="665" width="710" height="140" as="geometry"/>
        </mxCell>

        <!-- OUTPUT -->
        <mxCell id="output" value="Output: item.layer = str | None, item.layer_confidence = float" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A237E;strokeColor=#0D47A1;strokeWidth=3;fontSize=12;fontColor=#FFFFFF;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="870" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- FLOW ARROWS -->
        <mxCell id="a1" style="strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" source="input" target="tok" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" style="strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" source="tok" target="lex_box" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" style="strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" source="lex_box" target="conf_box" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a4" value="ambiguous?" style="strokeColor=#F57F17;strokeWidth=2;endArrow=blockThin;endFill=1;dashed=1;fontSize=10;fontColor=#F57F17;" edge="1" source="conf_box" target="llm_box" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a5" style="strokeColor=#37474F;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" source="conf_box" target="output" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a6" style="strokeColor=#F57F17;strokeWidth=2;endArrow=blockThin;endFill=1;dashed=1;" edge="1" source="llm_box" target="output" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
