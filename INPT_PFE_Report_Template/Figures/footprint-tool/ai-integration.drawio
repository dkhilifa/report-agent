                <mxCell id="title" value="AI Integration — LLM Provider Protocol, Backends &amp; Detection Chain" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#1A237E;" parent="1" vertex="1">
