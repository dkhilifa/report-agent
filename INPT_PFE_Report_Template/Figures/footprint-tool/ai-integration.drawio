                <mxCell id="ip1" value="① Scoring Signal&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Where: CompositeExternalSignalProvider&#xa;Method: score_mapping(src, tgt, context)&#xa;Purpose: Provide external_similarity score (weight=0.28)&#xa;Fallback: Returns 0.0, coverage decreases" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#6A1B9A;fontSize=10;fontColor=#4A148C;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="655" width="500" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ip2" value="② Layer Classification&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Where: LayerClassifier (ambiguous items)&#xa;Method: classify_layer(name, path, layers)&#xa;Purpose: Resolve ambiguous layer when lexicon fails&#xa;Fallback: Item remains unclassified (layer=None)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#6A1B9A;fontSize=10;fontColor=#4A148C;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="580" y="655" width="500" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ip3" value="③ Root Cause Tagging&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Where: RootCauseAnalyzer&#xa;Method: suggest_root_cause(item, context)&#xa;Purpose: Generate explanatory tags for anomalies&#xa;Fallback: Rule-based tags only (no AI explanation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#6A1B9A;fontSize=10;fontColor=#4A148C;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="655" width="520" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ip4" value="④ AI Chat Assistant&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Where: AIChatPanel (GUI)&#xa;Method: Free-form Q&amp;A with analysis context&#xa;Purpose: User asks questions about results&#xa;Fallback: Panel hidden, feature unavailable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#6A1B9A;fontSize=10;fontColor=#4A148C;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="780" width="500" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ip5" value="⑤ Mapping Explanation&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Where: ReviewPanel (on-demand)&#xa;Method: explain_mapping(src, tgt, signals)&#xa;Purpose: Human-readable justification for review&#xa;Fallback: Shows raw signal values instead" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#6A1B9A;fontSize=10;fontColor=#4A148C;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="580" y="780" width="500" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="principle" value="Design Principle: ALL AI features are gracefully degraded — the tool is 100% functional without any LLM provider configured" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A237E;strokeColor=#0D47A1;strokeWidth=3;fontSize=12;fontColor=#FFFFFF;fontStyle=1;" parent="1" vertex="1">
