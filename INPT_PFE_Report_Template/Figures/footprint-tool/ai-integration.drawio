                <mxCell id="proto_iface" value="class LLMProvider(Protocol):&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;  @abstractmethod&#xa;  def score_mapping(src: str, tgt: str, context: dict) → float&#xa;&#xa;  @abstractmethod&#xa;  def classify_layer(name: str, path: str, layers: list[str]) → str | None&#xa;&#xa;  @abstractmethod&#xa;  def explain_mapping(src: str, tgt: str, signals: dict) → str&#xa;&#xa;  @abstractmethod&#xa;  def suggest_root_cause(item: str, context: dict) → str | None&#xa;&#xa;  @property&#xa;  def is_available(self) → bool&#xa;&#xa;  @property&#xa;  def provider_name(self) → str" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F57F17;fontSize=10;fontColor=#E65100;align=left;spacingLeft=12;verticalAlign=top;spacingTop=5;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="60" y="120" width="660" height="225" as="geometry"/>
                </mxCell>
                <mxCell id="back_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;arcSize=3;" parent="1" vertex="1">
                    <mxGeometry x="790" y="80" width="870" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="back_label" value="② BACKENDS — Concrete Implementations" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontStyle=1;fontSize=14;fontColor=#1565C0;" parent="1" vertex="1">
                    <mxGeometry x="810" y="85" width="450" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="b_copilot" value="GitHubCopilotProvider&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• REST API (copilot.github.com)&#xa;• Model: GPT-4o&#xa;• Auth: GitHub token (env var)&#xa;• Rate limit: 10 req/min&#xa;• Timeout: 30s per call&#xa;• Primary provider (weight: 0.65)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;fontSize=10;fontColor=#0D47A1;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="810" y="125" width="270" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="b_openai" value="OpenAIProvider&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• REST API (api.openai.com)&#xa;• Model: configurable (gpt-4-turbo)&#xa;• Auth: API key (env var)&#xa;• Rate limit: per-key tier&#xa;• Timeout: 60s per call&#xa;• Fallback provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;fontSize=10;fontColor=#0D47A1;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="125" width="250" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="b_local" value="LocalLLMProvider (Ollama)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• REST API (localhost:11434)&#xa;• Model: codellama/mistral&#xa;• Auth: none (local)&#xa;• No rate limit&#xa;• Timeout: 120s (slower)&#xa;• Offline fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;fontSize=10;fontColor=#0D47A1;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="1370" y="125" width="260" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="b_null" value="NullProvider (no AI)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• Returns 0.0 for all scores&#xa;• Returns None for classifications&#xa;• Always available&#xa;• Used when all providers fail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=1;fontSize=10;fontColor=#B71C1C;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
