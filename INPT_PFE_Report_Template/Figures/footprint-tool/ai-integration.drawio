                <mxCell id="proto_label" value="① LLM PROVIDER PROTOCOL (Abstract Interface)" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontStyle=1;fontSize=14;fontColor=#F57F17;" parent="1" vertex="1">
                    <mxGeometry x="60" y="85" width="500" height="30" as="geometry"/>
