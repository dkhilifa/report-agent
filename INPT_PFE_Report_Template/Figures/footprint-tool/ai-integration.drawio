                <mxCell id="int_label" value="④ FIVE INTEGRATION POINTS — Where AI connects to the analysis pipeline" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontStyle=1;fontSize=14;fontColor=#6A1B9A;" parent="1" vertex="1">
