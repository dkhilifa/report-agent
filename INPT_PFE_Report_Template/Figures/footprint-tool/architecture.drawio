<mxfile host="app.diagrams.net" type="device">
  <diagram id="tool-arch" name="Architecture">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="740" math="0" shadow="0">
      <root>
